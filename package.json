{
  "name": "@sarxina/chatgod-js",
  "version": "0.1.5",
  "description": "Twitch chat + redeem manager with TTS, OBS control, and a React frontend",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "predev": "node scripts/setup.mjs",
    "dev": "concurrently -k -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd src/client && npm run build -- --watch",
    "dev:server": "tsx watch src/server.ts",
    "prebuild": "npm run build:client",
    "build": "npm run build:server",
    "build:client": "cd src/client && npm run build",
    "build:server": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist src/client/dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sarxina/chatgod-js.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sarxina/chatgod-js/issues"
  },
  "homepage": "https://github.com/Sarxina/chatgod-js#readme",
  "dependencies": {
    "@sarxina/sarxina-tools": "^0.1.5",
    "@twurple/auth": "^7.4.0",
    "@twurple/chat": "^7.4.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.46.0",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/socket.io": "^3.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  }
}
